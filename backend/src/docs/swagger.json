    "/v1/polls/{id}/analytics": {
      "get": {
        "tags": ["Analytics"],
        "description": "Get poll analytics (creator only)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Poll analytics data including response stats, question results, recent activity, and audience insights",
            "schema": {
              "type": "object",
              "properties": {
                "poll": { "type": "object" },
                "totalResponses": { "type": "number" },
                "goalProgress": { "type": "number", "nullable": true },
                "completionRate": { "type": "number" },
                "questions": { "type": "array", "items": { "type": "object" } },
                "recentVotes": { "type": "array", "items": { "type": "object" } },
                "audience": {
                  "type": "object",
                  "properties": {
                    "geographic": { "type": "array", "items": { "type": "object" } },
                    "devices": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
